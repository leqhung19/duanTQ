<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="DoAn.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:DoAn.Views"
    Shell.FlyoutBehavior="Disabled">

    <TabBar>
        <Tab Title="Home" Icon="home.png">
            <ShellContent Title="Home"
                          Route="HomePage"
                          ContentTemplate="{DataTemplate views:HomePage}" />
        </Tab>
        <Tab Title="Map" Icon="map.png">
            <ShellContent ContentTemplate="{DataTemplate views:MapPage}" />
        </Tab>
        <Tab Title="Scan QR" Icon="qr.png">
            <ShellContent ContentTemplate="{DataTemplate views:QRPage}" />
        </Tab>
    </TabBar>
    <ShellContent Title="Map"
                  Route="MapPage"
                  ContentTemplate="{DataTemplate views:MapPage}" />
</Shell>