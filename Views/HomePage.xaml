<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DoAn.Views.HomePage"
             Title="Khám phá">

    <Grid RowDefinitions="Auto,*">

        <!-- SEARCH BAR -->
        <SearchBar Grid.Row="0"
                   x:Name="SearchBar"
                   Placeholder="Tìm quán ăn..."
                   TextChanged="OnSearchChanged"
                   Margin="12,8"
                   BackgroundColor="White"/>

        <!-- DANH SÁCH QUÁN -->
        <RefreshView Grid.Row="1"
                     x:Name="RefreshView"
                     Refreshing="OnRefreshing">
            <CollectionView x:Name="RestaurantCollection"
                            SelectionMode="Single"
                            SelectionChanged="OnRestaurantSelected"
                            EmptyView="Không có quán nào">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="12,6" ColumnDefinitions="100,*">

                            <!-- Ảnh -->
                            <Image Grid.Column="0"
                                   Source="{Binding Image}"
                                   HeightRequest="90"
                                   WidthRequest="90"
                                   Aspect="AspectFill">
                                <Image.Clip>
                                    <RoundRectangleGeometry Rect="0,0,90,90" CornerRadius="10"/>
                                </Image.Clip>
                            </Image>

                            <!-- Thông tin -->
                            <VerticalStackLayout Grid.Column="1"
                                                 Padding="10,0,0,0"
                                                 Spacing="4"
                                                 VerticalOptions="Center">
                                <Label Text="{Binding Name}"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="#212121"/>
                                <Label Text="{Binding Address}"
                                       FontSize="13"
                                       TextColor="#757575"
                                       LineBreakMode="TailTruncation"/>
                                <Label Text="{Binding OpenTime}"
                                       FontSize="12"
                                       TextColor="#4CAF50"/>
                                <Label Text="{Binding PriceRange}"
                                       FontSize="12"
                                       TextColor="#FF5722"
                                       FontAttributes="Bold"/>
                            </VerticalStackLayout>

                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <!-- Loading -->
        <ActivityIndicator Grid.Row="1"
                           x:Name="LoadingIndicator"
                           IsRunning="False"
                           IsVisible="False"
                           Color="#FF5722"
                           VerticalOptions="Center"
                           HorizontalOptions="Center"/>

    </Grid>
</ContentPage>