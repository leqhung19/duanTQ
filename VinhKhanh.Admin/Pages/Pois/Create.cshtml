@page
@model VinhKhanh.Admin.Pages.Pois.CreateModel
@{
    ViewData["Title"] = "Tạo POI";
    ViewData["ActivePage"] = "Pois";
}

<div class="card border-0 shadow-sm">
    <div class="card-body p-4">

        <form method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <!-- ── THÔNG TIN ĐỊA ĐIỂM ── -->
            <h5 class="mb-3 pb-2 border-bottom">Thông tin địa điểm</h5>
            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label class="form-label">Tên địa điểm <span class="text-danger">*</span></label>
                    <input asp-for="Restaurant.Name" class="form-control"
                           placeholder="Ví dụ: Ốc Sáu Nở" />
                    <span asp-validation-for="Restaurant.Name" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Địa chỉ</label>
                    <input asp-for="Restaurant.Address" class="form-control"
                           placeholder="Địa chỉ hiển thị trong app" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Số điện thoại</label>
                    <input asp-for="Restaurant.Phone" class="form-control"
                           placeholder="0901234567" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Giờ mở cửa</label>
                    <input asp-for="Restaurant.OpenTime" class="form-control"
                           placeholder="08:00 - 22:00" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Ảnh từ máy tính</label>
                    <input type="file" name="ImageFile" class="form-control"
                           accept="image/*" />
                    <small class="text-muted">Ảnh lưu trên web và dùng lại cho app</small>
                </div>
            </div>

            <!-- ── MÔ TẢ ĐA NGÔN NGỮ ── -->
            <h5 class="mb-3 pb-2 border-bottom">Mô tả điểm</h5>
            <p class="text-muted small mb-2">
                💡 Chỉ cần nhập 1 ngôn ngữ — hệ thống tự dịch sang các ngôn ngữ còn lại khi lưu.
            </p>
            <div class="mb-4">
                <ul class="nav nav-tabs" id="descTab">
                    <li class="nav-item">
                        <a class="nav-link active" data-bs-toggle="tab" href="#dvi">🇻🇳 Việt</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" data-bs-toggle="tab" href="#den">🇬🇧 English</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" data-bs-toggle="tab" href="#dcn">🇨🇳 中文</a>
                    </li>
                </ul>
                <div class="tab-content border border-top-0 rounded-bottom p-3">
                    <div class="tab-pane fade show active" id="dvi">
                        <textarea asp-for="Restaurant.Description_vi" class="form-control"
                                  rows="3" placeholder="Mô tả ngắn bằng tiếng Việt..."></textarea>
                    </div>
                    <div class="tab-pane fade" id="den">
                        <textarea asp-for="Restaurant.Description_en" class="form-control"
                                  rows="3" placeholder="Short description in English..."></textarea>
                    </div>
                    <div class="tab-pane fade" id="dcn">
                        <textarea asp-for="Restaurant.Description_cn" class="form-control"
                                  rows="3" placeholder="中文描述..."></textarea>
                    </div>
                </div>
            </div>

            <!-- ── VỊ TRÍ ── -->
            <h5 class="mb-3 pb-2 border-bottom">Vị trí</h5>
            <div class="row g-3 mb-2">
                <div class="col-md-3">
                    <label class="form-label">Vĩ độ</label>
                    <input asp-for="Restaurant.Latitude" class="form-control" id="lat"
                           placeholder="10.7572" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Kinh độ</label>
                    <input asp-for="Restaurant.Longitude" class="form-control" id="lng"
                           placeholder="106.6931" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Bán kính (m)</label>
                    <input asp-for="Restaurant.RadiusMeters" class="form-control"
                           type="number" min="10" max="200" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Ưu tiên</label>
                    <input asp-for="Restaurant.Priority" class="form-control"
                           type="number" min="1" max="10" />
                </div>
            </div>

            <!-- Bản đồ chọn tọa độ -->
            <div id="map" style="height:280px;border-radius:8px;border:1px solid #ddd;margin-bottom:.5rem;"></div>
            <small class="text-muted">Nhấn vào bản đồ để chọn vị trí chính xác</small>

            <div class="form-check mt-2 mb-4">
                <input asp-for="Restaurant.IsActive" class="form-check-input" type="checkbox" />
                <label asp-for="Restaurant.IsActive" class="form-check-label">Đang hoạt động</label>
            </div>

            <!-- ── NỘI DUNG TTS ── -->
            <h5 class="mb-3 pb-2 border-bottom">Nội dung TTS (đọc khi khách đến gần)</h5>
            <p class="text-muted small mb-2">
                💡 Chỉ cần nhập 1 ngôn ngữ — hệ thống tự dịch sang các ngôn ngữ còn lại khi lưu.
            </p>
            <div class="mb-4">
                <ul class="nav nav-tabs" id="ttsTab">
                    <li class="nav-item">
                        <a class="nav-link active" data-bs-toggle="tab" href="#tvi">🇻🇳 TTS Việt</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" data-bs-toggle="tab" href="#ten">🇬🇧 TTS Anh</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" data-bs-toggle="tab" href="#tcn">🇨🇳 TTS Trung</a>
                    </li>
                </ul>
                <div class="tab-content border border-top-0 rounded-bottom p-3">
                    <div class="tab-pane fade show active" id="tvi">
                        <textarea asp-for="Restaurant.AudioContent_vi" class="form-control"
                                  rows="4" placeholder="Văn bản TTS đọc khi khách đến gần (tiếng Việt)..."></textarea>
                    </div>
                    <div class="tab-pane fade" id="ten">
                        <textarea asp-for="Restaurant.AudioContent_en" class="form-control"
                                  rows="4" placeholder="Text for TTS when visitor approaches (English)..."></textarea>
                    </div>
                    <div class="tab-pane fade" id="tcn">
                        <textarea asp-for="Restaurant.AudioContent_cn" class="form-control"
                                  rows="4" placeholder="访客靠近时TTS朗读的文字（中文）..."></textarea>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-success px-4">💾 Lưu POI</button>
                <a asp-page="Index" class="btn btn-outline-secondary">Huỷ</a>
            </div>
        </form>
    </div>
</div>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
@section Scripts {
    <script>
        const map = L.map('map').setView([10.7572, 106.6931], 16);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',
        { attribution: '© OpenStreetMap' }).addTo(map);

        let marker = null;
        map.on('click', e => {
        const { lat, lng } = e.latlng;
        document.getElementById('lat').value = lat.toFixed(7);
        document.getElementById('lng').value = lng.toFixed(7);
        if (marker) marker.setLatLng(e.latlng);
        else marker = L.marker(e.latlng).addTo(map);
        });

        // Nếu đã có tọa độ từ trước, đặt marker
        const existLat = parseFloat(document.getElementById('lat').value);
        const existLng = parseFloat(document.getElementById('lng').value);
        if (existLat && existLng) {
        marker = L.marker([existLat, existLng]).addTo(map);
        map.setView([existLat, existLng], 17);
        }
    </script>
}