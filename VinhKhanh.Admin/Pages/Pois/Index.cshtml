@page
@model VinhKhanh.Admin.Pages.Pois.IndexModel
@{
    ViewData["Title"] = "Điểm POI";
    ViewData["ActivePage"] = "Pois";
}

<!-- Stats row -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm text-center p-3">
            <div class="text-muted small">Tổng POI</div>
            <div class="fs-3 fw-bold">@Model.Restaurants.Count</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm text-center p-3">
            <div class="text-muted small">Đang hoạt động</div>
            <div class="fs-3 fw-bold text-success">@Model.Restaurants.Count(r => r.IsActive)</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm text-center p-3">
            <div class="text-muted small">Có lời thuyết minh</div>
            <div class="fs-3 fw-bold text-primary">
                @Model.Restaurants.Count(r => !string.IsNullOrEmpty(r.AudioContent_vi))
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm text-center p-3">
            <div class="text-muted small">Đa ngôn ngữ</div>
            <div class="fs-3 fw-bold text-info">
                @Model.Restaurants.Count(r =>
                    !string.IsNullOrEmpty(r.AudioContent_en) ||
                    !string.IsNullOrEmpty(r.AudioContent_kr) ||
                    !string.IsNullOrEmpty(r.AudioContent_cn))
            </div>
        </div>
    </div>
</div>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0">Danh sách POI</h5>
    <a asp-page="Create" class="btn btn-success btn-sm px-3">+ Thêm địa điểm</a>
</div>

@if (TempData["Message"] is string msg)
{
    <div class="alert alert-success alert-dismissible fade show">
        @msg <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- POI Grid -->
<div class="row g-3">
    @foreach (var r in Model.Restaurants)
    {
        <div class="col-md-6 col-lg-4">
            <div class="card border-0 shadow-sm h-100">
                <!-- Ảnh -->
                <div style="height:160px;overflow:hidden;border-radius:8px 8px 0 0;background:#f0f0f0;">
                    @if (!string.IsNullOrEmpty(r.Image))
                    {
                        <img src="/images/@r.Image" style="width:100%;height:100%;object-fit:cover;"
                             onerror="this.src='/images/placeholder.jpg'" />
                    }
                    else
                    {
                        <div style="height:100%;display:flex;align-items:center;justify-content:center;
                            font-size:3rem;color:#ccc;">
                            📍
                        </div>
                    }
                </div>

                <div class="card-body pb-2">
                    <!-- Tên + trạng thái -->
                    <div class="d-flex justify-content-between align-items-start mb-1">
                        <h6 class="mb-0 fw-bold">@r.Name</h6>
                        @if (r.IsActive)
                        {
                            <span class="badge bg-success" style="font-size:.7rem;">Hoạt động</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary" style="font-size:.7rem;">Tắt</span>
                        }
                    </div>

                    <!-- Địa chỉ -->
                    @if (!string.IsNullOrEmpty(r.Address))
                    {
                        <p class="text-muted small mb-1">📌 @r.Address</p>
                    }

                    <!-- Tọa độ + bán kính -->
                    <div class="row g-1 mb-2 small text-muted">
                        <div class="col-7">
                            Tọa độ: @r.Latitude.ToString("F5"), @r.Longitude.ToString("F5")
                        </div>
                        <div class="col-5 text-end">
                            Bán kính: @r.RadiusMeters m
                        </div>
                    </div>

                    <!-- Ngôn ngữ thuyết minh tự động có sẵn -->
                    <div class="mb-2">
                        <small class="text-muted me-1">Ngôn ngữ:</small>
                        @if (!string.IsNullOrEmpty(r.AudioContent_vi))
                        {
                            <span class="badge" style="background:#1565c0;font-size:.7rem;">VI</span>
                        }
                        @if (!string.IsNullOrEmpty(r.AudioContent_en))
                        {
                            <span class="badge" style="background:#2e7d32;font-size:.7rem;">EN</span>
                        }
                        @if (!string.IsNullOrEmpty(r.AudioContent_kr))
                        {
                            <span class="badge" style="background:#6a1b9a;font-size:.7rem;">KO</span>
                        }
                        @if (!string.IsNullOrEmpty(r.AudioContent_cn))
                        {
                            <span class="badge" style="background:#c62828;font-size:.7rem;">CN</span>
                        }
                    </div>

                    <div class="mb-2">
                        <small class="text-muted me-1">File thu âm:</small>
                        <span class="badge bg-secondary" style="font-size:.7rem;">@r.AudioFiles.Count(a => a.IsPublished)</span>
                    </div>

                    <!-- Ưu tiên -->
                    <small class="text-muted">Ưu tiên: <strong>@r.Priority</strong></small>
                </div>

                <!-- Actions -->
                <div class="card-footer bg-white border-top-0 pb-3">
                    <div class="input-group input-group-sm mb-2">
                        <select class="form-select" id="lang-@r.Id">
                            <option value="vi">Việt</option>
                            <option value="en">Anh</option>
                            <option value="ko">Hàn</option>
                            <option value="cn">Trung</option>
                        </select>
                        <button class="btn btn-outline-success" type="button"
                                onclick="previewTts(@r.Id, document.getElementById('lang-@r.Id').value)">
                            Nghe thử thuyết minh
                        </button>
                    </div>
                    <div class="d-flex gap-2">
                    <a asp-page="Edit" asp-route-id="@r.Id"
                       class="btn btn-sm btn-outline-primary">Sửa</a>
                    <a asp-page="Detail" asp-route-id="@r.Id"
                       class="btn btn-sm btn-outline-success">File thu âm</a>
                    <form method="post" asp-page-handler="Delete" asp-route-id="@r.Id"
                          onsubmit="return confirm('Xóa @r.Name?')">
                        <button class="btn btn-sm btn-outline-danger">Xóa</button>
                    </form>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        function previewTts(id, lang) {
            fetch(`/api/tts/preview?id=${id}&lang=${lang}`)
                .then(r => r.json())
                .then(d => {
                    if (d.text) {
                        const utter = new SpeechSynthesisUtterance(d.text);
                        utter.lang = lang === 'vi'
                            ? 'vi-VN'
                            : lang === 'en'
                                ? 'en-US'
                                : lang === 'ko'
                                    ? 'ko-KR'
                                    : 'zh-CN';
                        speechSynthesis.speak(utter);
                    }
                });
        }
    </script>
}
