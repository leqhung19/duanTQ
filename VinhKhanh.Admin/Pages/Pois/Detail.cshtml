@page "{id:int}"
@model VinhKhanh.Admin.Pages.Pois.DetailModel
@{
    ViewData["Title"] = $"File thuyết minh thu âm - {Model.Poi?.Name}";
    ViewData["ActivePage"] = "Pois";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2 class="mb-1">File thuyết minh thu âm</h2>
        <div class="text-muted">@Model.Poi?.Name</div>
    </div>
    <a asp-page="Index" class="btn btn-outline-secondary">Quay lại danh sách</a>
</div>

@if (TempData["Message"] is string msg)
{
    <div class="alert alert-success">@msg</div>
}
@if (TempData["Error"] is string err)
{
    <div class="alert alert-danger">@err</div>
}

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <h5 class="mb-3">Upload file thuyết minh theo ngôn ngữ</h5>
        <p class="text-muted small mb-3">
            App sẽ ưu tiên phát file này khi khách quét QR hoặc đến gần POI. Nếu chưa có file, app dùng lời thuyết minh tự động.
        </p>
        <form method="post" enctype="multipart/form-data" asp-page-handler="Upload" asp-route-id="@Model.Poi?.Id">
            <div class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label">Ngôn ngữ</label>
                    <select name="language" class="form-select" required>
                        <option value="vi">Tiếng Việt</option>
                        <option value="en">English</option>
                        <option value="ko">Tiếng Hàn</option>
                        <option value="cn">Tiếng Trung</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label">File thuyết minh (.mp3, .wav, .m4a)</label>
                    <input type="file" name="file" class="form-control" accept=".mp3,.wav,.m4a,audio/*" required />
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-primary w-100">Upload</button>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <h5 class="mb-3">File thuyết minh đã upload</h5>
        @if (!Model.AudioFiles.Any())
        {
            <div class="text-muted">Chưa có file thuyết minh thu âm nào.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Ngôn ngữ</th>
                            <th>File</th>
                            <th>Preview</th>
                            <th>Dung lượng</th>
                            <th>Trạng thái</th>
                            <th style="width:210px;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var audio in Model.AudioFiles)
                        {
                            <tr>
                                <td>@LanguageName(audio.Language)</td>
                                <td><small>@audio.FileName</small></td>
                                <td>
                                    <audio controls style="width:220px;height:32px;">
                                        <source src="@audio.FilePath" />
                                    </audio>
                                </td>
                                <td>@((audio.FileSizeBytes / 1024.0).ToString("F1")) KB</td>
                                <td>
                                    @if (audio.IsPublished)
                                    {
                                        <span class="badge bg-success">Dang sync</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Da an</span>
                                    }
                                </td>
                                <td>
                                    <div class="d-flex gap-2">
                                        <form method="post" asp-page-handler="Publish"
                                              asp-route-id="@Model.Poi?.Id"
                                              asp-route-audioId="@audio.Id"
                                              asp-route-publish="@(!audio.IsPublished)">
                                            <button class="btn btn-sm @(audio.IsPublished ? "btn-outline-warning" : "btn-outline-success")">
                                                @(audio.IsPublished ? "An" : "Publish")
                                            </button>
                                        </form>
                                        <form method="post" asp-page-handler="DeleteAudio"
                                              asp-route-id="@Model.Poi?.Id"
                                              asp-route-audioId="@audio.Id"
                                              onsubmit="return confirm('Xóa file thuyết minh này?')">
                                            <button class="btn btn-sm btn-outline-danger">Xóa</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@functions {
    private static string LanguageName(string language) => language switch
    {
        "vi" => "Tiếng Việt",
        "en" => "English",
        "ko" => "Tiếng Hàn",
        "cn" => "Tiếng Trung",
        _ => language
    };
}
