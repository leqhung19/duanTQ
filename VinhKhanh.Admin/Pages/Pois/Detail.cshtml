@*
@page "{id:int}"
@model VinhKhanh.Admin.Pages.Pois.DetailModel
@{
    ViewData["Title"] = $"Audio — {Model.Poi?.Name}";
}

<h2>Quản lý Audio — <em>@Model.Poi?.Name</em></h2>
<a asp-page="Index" class="btn btn-sm btn-outline-secondary mb-3">← Quay lại danh sách</a>

@if (TempData["Message"] is string msg)
{
    <div class="alert alert-success">@msg</div>
}
@if (TempData["Error"] is string err)
{
    <div class="alert alert-danger">@err</div>
}

<!-- Form upload -->
<div class="card mb-4">
    <div class="card-header"><strong>Upload file audio mới</strong></div>
    <div class="card-body">
        <form method="post" enctype="multipart/form-data" asp-page-handler="Upload">
            <input type="hidden" name="poiId" value="@Model.Poi?.Id" />
            <div class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label">Ngôn ngữ</label>
                    <select name="language" class="form-select">
                        <option value="vi">🇻🇳 Tiếng Việt</option>
                        <option value="en">🇬🇧 English</option>
                        <option value="zh">🇨🇳 中文</option>
                        <option value="ko">🇰🇷 한국어</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label">File audio (.mp3 / .wav — tối đa 20MB)</label>
                    <input type="file" name="file" class="form-control"
                           accept=".mp3,.wav,.m4a" required />
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-primary w-100">Upload</button>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Danh sách audio hiện có -->
<div class="card">
    <div class="card-header"><strong>Danh sách audio đã upload</strong></div>
    <div class="card-body p-0">
        @if (!Model.AudioFiles.Any())
        {
            <p class="p-3 text-muted">Chưa có file audio nào.</p>
        }
        else
        {
            <table class="table mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Ngôn ngữ</th>
                        <th>Tên file</th>
                        <th>Kích thước</th>
                        <th>Preview</th>
                        <th>Trạng thái</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var audio in Model.AudioFiles)
                    {
                        <tr>
                            <td>
                                @(audio.Language switch
                                {
                                    "vi" => "🇻🇳 Tiếng Việt",
                                    "en" => "🇬🇧 English",
                                    "zh" => "🇨🇳 中文",
                                    "ko" => "🇰🇷 한국어",
                                    _ => audio.Language
                                })
                            </td>
                            <td><small>@audio.FileName</small></td>
                            <td><small>@((audio.FileSizeBytes / 1024.0).ToString("F1")) KB</small></td>
                            <td>
                                <audio controls style="height:32px; width:200px;">
                                    <source src="@audio.FilePath" />
                                </audio>
                            </td>
                            <td>
                                @if (audio.IsPublished)
                                {
                                    <span class="badge bg-success">Đã duyệt</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">Chờ duyệt</span>
                                }
                            </td>
                            <td class="d-flex gap-1">
                                <form method="post" asp-page-handler="Publish"
                                      asp-route-audioId="@audio.Id"
                                      asp-route-publish="@(!audio.IsPublished)">
                                    <button class="btn btn-sm @(audio.IsPublished ? "btn-outline-warning" : "btn-outline-success")">
                                        @(audio.IsPublished ? "Huỷ duyệt" : "Duyệt")
                                    </button>
                                </form>
                                <form method="post" asp-page-handler="DeleteAudio"
                                      asp-route-audioId="@audio.Id"
                                      onsubmit="return confirm('Xóa file audio này?')">
                                    <button class="btn btn-sm btn-outline-danger">Xóa</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div> 

                                *@