@page
@model VinhKhanh.Admin.Pages.IndexModel
@{
    ViewData["Title"] = "Tổng quan";
    ViewData["ActivePage"] = "Dashboard";
}

<!-- Stat cards -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small">POI hoạt động</div>
                <div class="fs-3 fw-bold text-primary">
                    @Model.ActivePois / @Model.TotalPois
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small">Người dùng app hiện tại</div>
                <div class="fs-3 fw-bold text-success" id="activeCount">
                    @Model.ActiveUsers
                </div>
                <div id="liveDot" class="@(Model.ActiveUsers>0?"":"d-none")"
                     style="display:inline-flex;align-items:center;gap:.3rem;font-size:.75rem;color:#2e7d32;">
                    <span style="width:8px;height:8px;border-radius:50%;background:#2e7d32;
                                 animation:pulse 1.5s infinite;display:inline-block;"></span> Live
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small">Lượt nghe hôm nay</div>
                <div class="fs-3 fw-bold text-warning">@Model.TodayListens</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small">Tổng lượt nghe</div>
                <div class="fs-3 fw-bold text-info">@Model.TotalListens</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small">QR quét hôm nay</div>
                <div class="fs-3 fw-bold text-danger">@Model.TodayQrScans</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small">Tổng lượt quét QR</div>
                <div class="fs-3 fw-bold text-dark">@Model.TotalQrScans</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <!-- Điểm được nghe nhiều nhất -->
    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white fw-600">🏆 Điểm được nghe nhiều nhất</div>
            <div class="card-body p-0">
                <table class="table table-sm mb-0">
                    <thead class="table-light">
                        <tr><th>#</th><th>Tên điểm</th><th>Lượt nghe</th></tr>
                    </thead>
                    <tbody>
                    @{ int rank = 1; }
                    @foreach (var item in Model.TopPois)
                    {
                        <tr>
                            <td class="text-muted">@rank</td>
                            <td><strong>@item.Name</strong></td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="progress flex-grow-1" style="height:6px;">
                                        <div class="progress-bar bg-success"
                                             style="width:@item.Percent%"></div>
                                    </div>
                                    <span class="small">@item.Count</span>
                                </div>
                            </td>
                        </tr>
                        rank++;
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Ngôn ngữ đang hỗ trợ -->
    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white fw-600">🌐 Ngôn ngữ đang hỗ trợ</div>
            <div class="card-body">
                @foreach (var lang in Model.SupportedLanguages)
                {
                    var color = lang.Code switch
                    {
                        "vi" => "#1565c0",
                        "en" => "#2e7d32",
                        "ko" => "#6a1b9a",
                        "cn" => "#c62828",
                        _ => "#6c757d"
                    };
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="badge"
                              style="background:@color;color:white;font-size:.8rem;padding:.3rem .7rem;">
                            @lang.Code.ToUpper()
                        </span>
                        <strong class="small">@lang.Name</strong>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Lượt nghe gần nhất -->
    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white fw-600">🕐 Lượt nghe gần nhất </div>
            <div class="card-body p-0">
                @foreach (var log in Model.RecentLogs)
                {
                    <div class="px-3 py-2 border-bottom">
                        <div class="small fw-bold text-truncate">
                            @(log.Restaurant?.Name ?? "?")
                        </div>
                        <div class="d-flex justify-content-between">
                            <span class="badge bg-secondary" style="font-size:.7rem;">
                                @log.Language.ToUpper()
                            </span>
                            <small class="text-muted">
                                @IndexModel.ToVietnamTime(log.ListenedAt).ToString("HH:mm")
                            </small>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm mt-3">
    <div class="card-header bg-white fw-600">Lịch sử quét QR gần nhất</div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Thời gian</th>
                        <th>POI</th>
                        <th>Mã QR</th>
                        <th>Thiết bị</th>
                        <th>Khách ẩn danh</th>
                    </tr>
                </thead>
                <tbody>
                @if (!Model.RecentQrScans.Any())
                {
                    <tr>
                        <td colspan="5" class="text-muted text-center py-3">
                            Chưa có lượt quét QR nào.
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var scan in Model.RecentQrScans)
                    {
                        var vnTime = IndexModel.ToVietnamTime(scan.ScannedAt);
                        <tr>
                            <td class="text-nowrap">@vnTime.ToString("dd/MM/yyyy HH:mm")</td>
                            <td><strong>@(scan.Restaurant?.Name ?? "?")</strong></td>
                            <td><code>@scan.QrCode</code></td>
                            <td>
                                <span class="badge bg-secondary">@scan.DevicePlatform.ToUpper()</span>
                            </td>
                            <td class="text-muted small">
                                @(string.IsNullOrWhiteSpace(scan.AnonymousSessionId)
                                    ? "-"
                                    : scan.AnonymousSessionId[..Math.Min(8, scan.AnonymousSessionId.Length)])
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
<style>
@@keyframes pulse {
    0%,100%{opacity:1;transform:scale(1);}
    50%{opacity:.4;transform:scale(1.4);}
}
</style>
<script>
(() => {
    const activeCount = document.getElementById("activeCount");
    const liveDot = document.getElementById("liveDot");

    if (!activeCount || !liveDot) return;

    const applyCount = (count) => {
        activeCount.textContent = count;
        liveDot.classList.toggle("d-none", count <= 0);
    };

    const refreshActiveUsers = async () => {
        try {
            const response = await fetch("/api/sync/session/active-users", {
                cache: "no-store"
            });
            if (!response.ok) return;

            const data = await response.json();
            applyCount(Number(data.activeUsers || 0));
        } catch {
            // Giữ nguyên số cũ nếu API lỗi.
        }
    };

    refreshActiveUsers();
    setInterval(refreshActiveUsers, 2000);

    document.addEventListener("visibilitychange", () => {
        if (!document.hidden) {
            refreshActiveUsers();
        }
    });

    window.addEventListener("focus", refreshActiveUsers);
})();
</script>
}
